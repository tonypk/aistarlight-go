# Database
DATABASE_URL=postgres://aistarlight:devpass@localhost:5432/aistarlight?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
GIN_MODE=debug

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Cloud Storage
GCS_BUCKET=
GCS_CREDENTIALS_FILE=

# OCR Service
OCR_SERVICE_URL=http://localhost:8010

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Log
LOG_LEVEL=debug
LOG_FORMAT=text
