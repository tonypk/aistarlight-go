# ============================================================
# AIStarlight Go — Environment Configuration
# ============================================================
# Copy to .env and fill in values

# Database (used by Docker Compose and app)
POSTGRES_USER=aistarlight
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=aistarlight
DATABASE_URL=postgres://aistarlight:change-me-in-production@localhost:5432/aistarlight?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
GIN_MODE=debug

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Cloud Storage
GCS_BUCKET=
GCS_CREDENTIALS_FILE=

# OCR Service
OCR_SERVICE_URL=http://localhost:8001

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Log
LOG_LEVEL=debug
LOG_FORMAT=text

# Domain (used by Nginx / deploy)
DOMAIN=tax.clawpapa.win
